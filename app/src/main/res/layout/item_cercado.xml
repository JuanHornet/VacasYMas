<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="6dp"
    android:layout_marginBottom="6dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="@drawable/ripple_btn_dashboard"
    app:cardCornerRadius="16dp"
    app:cardElevation="3dp"
    app:cardBackgroundColor="@android:color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <TextView
            android:id="@+id/tvNombreCercado"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Cercado norte"
            android:textColor="#173B3F"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvDetalleCercado"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Dehesa · 14.5 ha"
            android:textColor="#4B5563"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvObservacionesCercado"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Zona con charca"
            android:textColor="#6B7280"
            android:textSize="13sp" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>